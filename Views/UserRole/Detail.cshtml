@model IList<string>

@{
    ViewData["Title"] = "User Roles Detail";
    string firstName = ViewBag.FirstName ?? string.Empty;
    string lastName = ViewBag.LastName ?? string.Empty;
    string email = ViewBag.Email ?? string.Empty;
}

<h2>Roles for @firstName @lastName</h2>

@if (ViewBag.ConfirmationMessage != null)
{
    <div class="alert alert-success">@ViewBag.ConfirmationMessage</div>
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

@if (Model.Count == 0)
{
    <p>No roles assigned to this user.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Role</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model)
            {
                <tr>
                    <td>@role</td>
                    <td>
                        <form asp-action="DeleteUserRole" method="post" style="display:inline;">
                            <input type="hidden" name="email" value="@email" />
                            <input type="hidden" name="roleName" value="@role" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div>
    <a asp-action="Index">Back to User List</a>
</div>
